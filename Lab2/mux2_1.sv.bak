module mux2_1 (a, b, sel, out)
	output logic out;
	input logic, a, b, sel;
	
	wire notSel, x, y;
	
	not #50 (notSel, sel);
	and #50 (x, notSel, a);
	and #50 (y, Sel, b);
	or  #50 (out, y, x);
endmodule;

module mux2_1_testbench();
	logic a, b, sel;
	logic, out;
	
	mux2_1 dut (.out, .i0, .i1, .sel);
	
	initial begin
			sel=0; i0=0; i1=0; #10;
			sel=0; i0=0; i1=1; #10;
			sel=0; i0=1; i1=0; #10;
			sel=0; i0=1; i1=1; #10;
			sel=1; i0=0; i1=0; #10;
			sel=1; i0=0; i1=1; #10;
			sel=1; i0=1; i1=0; #10;
			sel=1; i0=1; i1=1; #10;
		end
endmodule
